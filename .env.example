# Copy this file to .env and replace every placeholder with deployment secrets.
# Do not commit .env.

MYSQL_DATABASE=blog
MYSQL_USER=blog_user
MYSQL_PASSWORD=replace_with_strong_database_password
MYSQL_ROOT_PASSWORD=replace_with_strong_root_password

# Optional first-admin bootstrap. Remove after the admin account exists.
BLOG_ADMIN_USERNAME=
BLOG_ADMIN_PASSWORD=

# OSS configuration. Leave blank only if the deployment does not use media upload.
OSS_ENDPOINT=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET_NAME=
OSS_CDN_DOMAIN=
OSS_REGION=

BLOG_COMMENT_MODERATION_MAX_LINKS=2
BLOG_COMMENT_MODERATION_BLOCKED_KEYWORDS=
BLOG_COMMENT_MODERATION_AUTO_REJECT_BLOCKED_KEYWORDS=true

FRONTEND_PORT=80
